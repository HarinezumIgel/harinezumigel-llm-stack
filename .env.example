# ---------------------------------------------------------------------------
# Core paths
# ---------------------------------------------------------------------------
LITELLM_CONFIG=/opt/litellm/config.yaml
MODEL_ROOT=/opt/models

LITELLM_VENV_ACTIVATE=/opt/litellm/venv/bin/activate
LITELLM_BIN=/opt/litellm/venv/bin/litellm

# ---------------------------------------------------------------------------
# LiteLLM proxy bind
# ---------------------------------------------------------------------------
LITELLM_BIND_HOST=0.0.0.0
LITELLM_PORT=4000

# ---------------------------------------------------------------------------
# Shared vLLM host / bind
# VLLM_HOST is used to build API_BASE URLs.
# VLLM_BIND_HOST is used for Docker host-port binding.
# Usually these are the same on your Spark box.
# ---------------------------------------------------------------------------
VLLM_HOST=<vllm host>                                           # Must adjust
VLLM_BIND_HOSTA<bind_host>                                      # Must adjust
VLLM_CONTAINER_PORT=8000

# ---------------------------------------------------------------------------
# Docker runtime image and mounts
# ---------------------------------------------------------------------------
#
# You should check for new docker image versions periodically
VLLM_DOCKER_IMAGE=nvcr.io/nvidia/vllm:26.05.post1-py3
VLLM_MODEL_VOLUME=/opt/models:/models
VLLM_CACHE_VOLUME=/opt/vllm-cache:/root/.cache/huggingface

# Optional auto-port range
VLLM_AUTO_PORT_START=8001
VLLM_AUTO_PORT_END=8010

# ---------------------------------------------------------------------------
# LiteLLM proxy key
# Client -> LiteLLM uses this.
# ---------------------------------------------------------------------------
#
# Litellm requires a sk- prefix
#
LITELLM_MASTER_KEY=<sk- the secret to connect to litellm proxy> # Must Adjust

# ---------------------------------------------------------------------------
# Shared backend key
# LiteLLM uses this to authenticate requests to vLLM containers.
# The same value must be passed to each vLLM container as --api-key.
# ---------------------------------------------------------------------------
LOCAL_VLLM_API_KEY=

# ---------------------------------------------------------------------------
# Backend ports
# ---------------------------------------------------------------------------
MISTRAL_7B_PORT=8001
LLAMA_3_1_8B_PORT=8002
LLAMA_GUARD3_8B_PORT=8003
QWEN2_5_32B_AWQ_PORT=8004
QWEN_CODER_3_NEXT_PORT=8005
QWEN_3_6_27B_PORT=8006
DEEPSEEK_CODER_6_7B_PORT=8007
DEEPSEEK_V4_PRO_70B_PORT=8008

# ---------------------------------------------------------------------------
# Full API bases
# LiteLLM reads these as whole env vars from config.yaml.
# ---------------------------------------------------------------------------
MISTRAL_7B_API_BASE=http://${VLLM_HOST}:${MISTRAL_7B_PORT}/v1
LLAMA_3_1_8B_API_BASE=http://${VLLM_HOST}:${LLAMA_3_1_8B_PORT}/v1
LLAMA_GUARD3_8B_API_BASE=http://${VLLM_HOST}:${LLAMA_GUARD3_8B_PORT}/v1
QWEN2_5_32B_AWQ_API_BASE=http://${VLLM_HOST}:${QWEN2_5_32B_AWQ_PORT}/v1
QWEN3_CODER_3_NEXT_API_BASE=http://${VLLM_HOST}:${QWEN_CODER_3_NEXT_PORT}/v1
QWEN_3_6_27B_API_BASE=http://${VLLM_HOST}:${QWEN_3_6_27B_PORT}/v1
DEEPSEEK_CODER_6_7B_API_BASE=http://${VLLM_HOST}:${DEEPSEEK_CODER_6_7B_PORT}/v1
DEEPSEEK_V4_PRO_70B_API_BASE=http://${VLLM_HOST}:${DEEPSEEK_V4_PRO_70B_PORT}/v1
