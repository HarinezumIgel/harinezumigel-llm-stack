# Example Environment Configuration for setupllm.py
# Copy this file to /opt/litellm/.env and customize for your setup

# ============================================================================
# LiteLLM Proxy Configuration
# ============================================================================

# Path to LiteLLM config.yaml
LITELLM_CONFIG=/opt/litellm/config.yaml

# LiteLLM virtual environment activation script
LITELLM_VENV_ACTIVATE=/opt/litellm/venv/bin/activate

# LiteLLM binary path
LITELLM_BIN=/opt/litellm/venv/bin/litellm

# LiteLLM proxy bind address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
LITELLM_BIND_HOST=0.0.0.0

# LiteLLM proxy port
LITELLM_PORT=4000

# ============================================================================
# Model Storage
# ============================================================================

# Root directory containing downloaded model files
# Models should be in subdirectories under this path
MODEL_ROOT=/data/models

# ============================================================================
# vLLM Configuration
# ============================================================================

# Hostname where vLLM containers will be accessible
# Use 'localhost' for single-machine deployments
VLLM_HOST=localhost

# vLLM container bind address
# 0.0.0.0 = accessible from all interfaces
# 127.0.0.1 = localhost only
VLLM_BIND_HOST=0.0.0.0

# Internal container port (vLLM default is 8000)
VLLM_CONTAINER_PORT=8000

# Docker image to use for vLLM containers
# See https://hub.docker.com/r/vllm/vllm-openai/tags for available versions
VLLM_DOCKER_IMAGE=vllm/vllm-openai:latest

# ============================================================================
# Docker Volume Mounts
# ============================================================================

# Model files volume (host:container:mode)
# Mode should be 'ro' (read-only) to prevent accidental modifications
VLLM_MODEL_VOLUME=/data/models:/models:ro

# Hugging Face cache volume (for tokenizers, configs, etc.)
# Mode should be 'rw' (read-write) for caching
VLLM_CACHE_VOLUME=/data/huggingface-cache:/root/.cache/huggingface:rw

# ============================================================================
# Port Allocation
# ============================================================================

# Port range for automatic port allocation (when using --auto-port)
VLLM_AUTO_PORT_START=8001
VLLM_AUTO_PORT_END=8010

# ============================================================================
# Security (Optional)
# ============================================================================

# API key for vLLM endpoints
# If set, clients must provide this key to access models
# Leave empty to disable authentication (not recommended for public networks)
LOCAL_VLLM_API_KEY=your-secret-api-key-here

# ============================================================================
# Advanced Options (Optional)
# ============================================================================

# Uncomment and customize as needed

# Custom Docker network
# VLLM_DOCKER_NETWORK=llm-network

# GPU device selection (default: all)
# VLLM_GPU_DEVICES=0,1

# Additional Docker run flags
# VLLM_DOCKER_EXTRA_FLAGS=--shm-size=1g
