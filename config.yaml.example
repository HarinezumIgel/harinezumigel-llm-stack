
config_metadata:
  repository_license: "MIT"
  third_party_model_notice: >
    This configuration references third-party models.
    Model licenses, usage rights, and restrictions are determined by
    the upstream model publishers. Consult the 'upstream' URL for the
    current license and terms applicable to each model.

model_list:
  # ---------------------------------------------------------------------------
  # Safety / moderation
  # ---------------------------------------------------------------------------
  - model_name: llama_guard3_8b
    litellm_params:
      litellm_provider: openai
      model: openai/llama_guard3_8b
      api_base: os.environ/LLAMA_GUARD3_8B_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 60
      temperature: 0.0
      top_p: 1.0
    model_info:
      model_dir: llama-guard3-8b
      context_length: 2048
      max_input_tokens: 1536
      max_output_tokens: 64
      max_tokens: 64
      gpu_memory_utilization: 0.20
      max_num_seqs: 8
      max_num_batched_tokens: 2048
      dtype: auto
      description: "Llama Guard 3 8B safety/moderation model"
      alias: "guard"
      license: "See upstream model license"
      upstream: "https://huggingface.co/meta-llama/Llama-Guard-3-8B"

  # ---------------------------------------------------------------------------
  # Fast general-purpose model
  # ---------------------------------------------------------------------------
  - model_name: llama_3_1_8b
    litellm_params:
      litellm_provider: openai
      model: openai/llama_3_1_8b
      api_base: os.environ/LLAMA_3_1_8B_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 90
      temperature: 0.7
      top_p: 0.9
    model_info:
      model_dir: llama3.1-8b
      context_length: 24576
      max_input_tokens: 20480
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.45
      max_num_seqs: 8
      max_num_batched_tokens: 16384
      enable_prefix_caching: true
      dtype: auto
      description: "Llama 3.1 8B fast general-purpose model"
      alias: "llama"
      license: "See upstream model license"
      upstream: "https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct"

  # ---------------------------------------------------------------------------
  # Fast lightweight fallback
  # ---------------------------------------------------------------------------
  - model_name: mistral_7b
    litellm_params:
      litellm_provider: openai
      model: openai/mistral_7b
      api_base: os.environ/MISTRAL_7B_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 90
      temperature: 0.7
      top_p: 0.9
    model_info:
      model_dir: mistral-7b-instruct-v0.3
      context_length: 24576
      max_input_tokens: 20480
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.45
      max_num_seqs: 8
      max_num_batched_tokens: 16384
      enable_prefix_caching: true
      dtype: auto
      description: "Mistral 7B fast lightweight fallback model"
      alias: "mistral"
      license: "See upstream model license"
      upstream: "https://huggingface.co/mistralai/Mistral-7B-Instruct-v0.3"

  # ---------------------------------------------------------------------------
  # Qwen2.5 32B AWQ
  # ---------------------------------------------------------------------------
  - model_name: qwen2_5_32b_awq
    litellm_params:
      litellm_provider: openai
      model: openai/qwen2_5_32b_awq
      api_base: os.environ/QWEN2_5_32B_AWQ_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 180
      temperature: 0.3
      top_p: 0.9
      top_k: 20
    model_info:
      model_dir: qwen2.5-32b-awq
      context_length: 32768
      max_input_tokens: 28672
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.90
      max_num_seqs: 1
      max_num_batched_tokens: 16384
      quantization: null
      kv_cache_dtype: auto
      generation_config: vllm
      enable_prefix_caching: true
      attention_backend: flashinfer
      dtype: auto
      description: "Qwen2.5 32B AWQ 4-bit"
      alias: "qwen32"
      license: "See upstream model license"
      upstream: "https://huggingface.co/Qwen/Qwen2.5-32B-Instruct-AWQ"

  # ---------------------------------------------------------------------------
  # Qwen3-Coder-Next AWQ: BIG CONTEXT profile
  # ---------------------------------------------------------------------------
  - model_name: Qwen3-Coder-Next-AWQ
    litellm_params:
      litellm_provider: openai
      model: openai/Qwen3-Coder-Next-AWQ
      api_base: os.environ/QWEN3_CODER_3_NEXT_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 240
      temperature: 0.2
      top_p: 0.9
      top_k: 20
    model_info:
      model_dir: Qwen3-Coder-Next-AWQ

      context_length:   262144
      max_input_tokens: 250000
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.90
      max_num_seqs: 1
      max_num_batched_tokens: 8192
      quantization: compressed-tensors
      kv_cache_dtype: fp8
      generation_config: vllm
      enable_auto_tool_choice: true
      tool_call_parser: qwen3_coder
      enable_prefix_caching: true
      attention_backend: flashinfer
      enforce_eager: false

      dtype: auto
      description: "Qwen3-Coder-Next AWQ big-context profile"
      alias: "coder"
      license: "See upstream model license"
      upstream: "https://huggingface.co/Qwen/Qwen3-Coder-Next"

  # ---------------------------------------------------------------------------
  # qwen3.6-27b Standard coding / chat model
  # ---------------------------------------------------------------------------
  - model_name: qwen3.6-27b
    litellm_params:
      litellm_provider: openai
      model: openai/qwen3.6-27b
      api_base: os.environ/QWEN_3_6_27B_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 240
      temperature: 0.3
      top_p: 0.9
      top_k: 20
    model_info:
      model_dir: Qwen3.6-27B

      context_length: 65536
      max_input_tokens: 60000
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.94
      max_num_seqs: 8
      max_num_batched_tokens: 32768
      quantization: null
      kv_cache_dtype: fp8
      generation_config: vllm
      attention_backend: flashinfer
      enable_prefix_caching: true
      enforce_eager: false
      enable_auto_tool_choice: true
      tool_call_parser: qwen3_coder

      dtype: auto
      description: "Qwen3.6 27B balanced coding/chat profile"
      alias: "chat"
      license: "See upstream model license"
      upstream: "https://huggingface.co/Qwen/Qwen3.6-27B"

  # ---------------------------------------------------------------------------
  # DeepSeek-Coder 6.7B RAG / fast tasks
  # ---------------------------------------------------------------------------
  - model_name: deepseek-coder-6.7b-instruct
    litellm_params:
      litellm_provider: openai
      model: openai/deepseek-coder-6.7b-instruct
      api_base: os.environ/DEEPSEEK_CODER_6_7B_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 120
      temperature: 0.2
      top_p: 0.9
      top_k: 20
    model_info:
      model_dir: deepseek-coder-6.7b-instruct

      context_length: 32768
      max_input_tokens: 28000
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.50
      max_num_seqs: 8
      max_num_batched_tokens: 16384
      generation_config: vllm
      attention_backend: flashinfer
      enable_prefix_caching: true
      enforce_eager: false

      dtype: auto
      description: "DeepSeek-Coder 6.7B fast coding/RAG model"
      alias: "fast-coder"
      license: "See upstream model license"
      upstream: "https://huggingface.co/deepseek-ai/deepseek-coder-6.7b-instruct"

  # ---------------------------------------------------------------------------
  # DeepSeek-V4-Pro Frontier reasoning / coding model
  # ---------------------------------------------------------------------------
  - model_name: deepseek-v4-pro-70b
    litellm_params:
      litellm_provider: openai
      model: openai/deepseek-v4-pro-70b
      api_base: os.environ/DEEPSEEK_V4_PRO_70B_API_BASE
      api_key: os.environ/LOCAL_VLLM_API_KEY
      request_timeout: 600
      temperature: 0.2
      top_p: 0.95
      top_k: 20

    model_info:
      model_dir: deepseek-v4-pro-70b

      context_length: 32768
      max_input_tokens: 28000
      max_output_tokens: 4096
      max_tokens: 4096
      gpu_memory_utilization: 0.75
      max_num_seqs: 1
      max_num_batched_tokens: 8192
      quantization: null
      kv_cache_dtype: fp8
      generation_config: vllm
      enable_prefix_caching: true
      enable_auto_tool_choice: true
      tool_call_parser: qwen3_coder
      attention_backend: flashinfer
      enforce_eager: false

      dtype: auto

      description: "DeepSeek-V4-Pro-70b frontier reasoning/coding profile (1M context)"
      alias: "reasoning"
      license: "See upstream model license"
      upstream: "https://huggingface.co/deepseek-ai/DeepSeek-V4-Pro"

router_settings:
  routing_strategy: simple-shuffle

litellm_settings:
  drop_params: true
  set_verbose: false
  request_timeout: 240
  json_logs: true
  turn_off_message_logging: true
  redact_user_api_key_info: true

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY

